# Server
PORT=4000
NODE_ENV=development

# PostgreSQL
PGHOST=localhost
PGPORT=5432
PGDATABASE=school_management
PGUSER=postgres
PGPASSWORD=change_me
PG_POOL_MAX=10

# Auth
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=8h

# Bootstrap super admin (created by scripts/seed.js if no users exist)
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=change_me
